generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model alerts {
  id        String    @id
  userId    String
  productId String?
  type      AlertType
  message   String
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  products  products? @relation(fields: [productId], references: [id])
  users     users     @relation(fields: [userId], references: [id])
}

model categories {
  id          String     @id
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  products    products[]
}

model economic_data {
  id        String   @id
  country   String   @default("RW")
  indicator String
  value     Float
  year      Int
  source    String
  fetchedAt DateTime @default(now())

  @@unique([country, indicator, year])
}

model exchange_rates {
  id           String   @id
  fromCurrency String
  toCurrency   String
  rate         Float
  fetchedAt    DateTime @default(now())
}

model products {
  id                String       @id
  name              String
  barcode           String?      @unique
  sku               String?      @unique
  categoryId        String
  userId            String
  costPrice         Float
  sellingPrice      Float
  suggestedMinPrice Float?
  suggestedMaxPrice Float?
  quantity          Int          @default(0)
  lowStockThreshold Int          @default(10)
  unit              String       @default("piece")
  manufacturingDate DateTime?
  expiryDate        DateTime?
  batchNumber       String?
  supplier          String?
  imageUrl          String?
  stockMethod       StockMethod  @default(FIFO)
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime
  alerts            alerts[]
  categories        categories   @relation(fields: [categoryId], references: [id])
  users             users        @relation(fields: [userId], references: [id])
  sale_items        sale_items[]
  stock_logs        stock_logs[]
}

model sale_items {
  id         String   @id
  saleId     String
  productId  String
  quantity   Int
  unitPrice  Float
  costPrice  Float
  totalPrice Float
  profit     Float
  products   products @relation(fields: [productId], references: [id])
  sales      sales    @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model sales {
  id          String       @id
  userId      String
  totalAmount Float
  totalProfit Float        @default(0)
  paymentMode PaymentMode  @default(CASH)
  notes       String?
  createdAt   DateTime     @default(now())
  sale_items  sale_items[]
  users       users        @relation(fields: [userId], references: [id])
}

model stock_logs {
  id          String       @id
  productId   String
  type        StockLogType
  quantity    Int
  reason      String?
  previousQty Int
  newQty      Int
  createdAt   DateTime     @default(now())
  products    products     @relation(fields: [productId], references: [id])
}

model users {
  id           String     @id
  name         String
  email        String     @unique
  password     String
  businessName String
  role         Role       @default(OWNER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  alerts       alerts[]
  products     products[]
  sales        sales[]
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  EXPIRY_SOON
  EXPIRED
  PRICE_SUGGESTION
  INFLATION_ALERT
}

enum PaymentMode {
  CASH
  MOBILE_MONEY
  CARD
  CREDIT
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum StockLogType {
  IN
  OUT
  ADJUSTMENT
  SALE
  RETURN
  EXPIRED
}

enum StockMethod {
  FIFO
  LIFO
}
